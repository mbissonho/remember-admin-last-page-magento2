<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <type name="Magento\Backend\Controller\Adminhtml\Auth\Logout">
        <plugin name="set_success_flag_to_url_on_admin_logout_after"
                type="Mbissonho\RememberAdminLastPage\Plugin\AdminLogoutAfter"
        />
    </type>

    <type name="Mbissonho\RememberAdminLastPage\Controller\Adminhtml\Index\IsLoggedIn">
        <arguments>
            <argument name="url" xsi:type="object">Magento\Backend\Model\UrlInterface\Proxy</argument>
        </arguments>
    </type>

    <!--
        Resume a stale-secret-key bounce back to its own page instead of the
        dashboard, fully server-side (see the plugin's class docblock). Applies
        to every admin controller that extends Magento\Backend\App\AbstractAction.
    -->
    <type name="Magento\Backend\App\AbstractAction">
        <plugin name="mbissonho_remember_admin_last_page_resume_on_secret_key_bounce"
                type="Mbissonho\RememberAdminLastPage\Plugin\Backend\ResumeOnSecretKeyBounce"/>
    </type>

</config>
