MAGENTO_BASE_URL="https://248community.test"
MAGENTO_ADMIN_USERNAME="mbissonho"
MAGENTO_ADMIN_PASSWORD="123@mudar"

# --- Magento CLI (used by global-setup.js to verify the scenario) ---
# Defines how `bin/magento` is invoked. Reusable across environments.
#
# "true"  -> run the CLI inside a container via `docker exec`
# "false" -> run the CLI directly on the host/runner (`php bin/magento`)
MAGENTO_CLI_IN_CONTAINER="true"
# Magento root used as the working dir (path INSIDE the container in container
# mode; path on the host in direct mode).
MAGENTO_ROOT="/var/www/html"
# Container name (container mode only).
#   docker-magento (local): 248community-phpfpm-1
#   Warden:                  <project>-php-fpm-1
#   GitHub Actions (flow):   e2e-magento2
MAGENTO_CLI_CONTAINER="248community-phpfpm-1"
# Container user (optional). docker-magento: app | Warden/CI: www-data
MAGENTO_CLI_CONTAINER_USER="app"

# Direct mode example (no container), e.g. a runner with Magento installed natively:
# MAGENTO_CLI_IN_CONTAINER="false"
# MAGENTO_ROOT="/var/www/html"
